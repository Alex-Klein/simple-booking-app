# Minimum number of nights required per booking (default: 2)
MIN_STAY=2

# Port the backend listens on (default: 3001)
PORT=3001

# Domain name — used by the nginx reverse proxy and SSL certificate
DOMAIN=yourcabin.com

# Email for Let's Encrypt certificate notifications (expiry warnings etc.)
CERTBOT_EMAIL=you@example.com

APP_NAME=My Cabin
VITE_APP_NAME=My Cabin

# Hero background images — comma-separated paths relative to /public (default: /bg.jpg)
# Place your images in the public/ folder and list them here
VITE_BG_IMAGES=/bg1.jpg,/bg2.jpg,/bg3.jpg

# How long each background image is shown in milliseconds (default: 6000)
VITE_BG_INTERVAL=6000
RESEND_API_KEY=re_your_key_here
ADMIN_EMAIL=admin@example.com
FROM_EMAIL=noreply@yourcabin.com
# Friendly sender name shown in email clients (defaults to APP_NAME if not set)
FROM_NAME=My Cabin
ADMIN_PASSWORD=changeme
JWT_SECRET=change-this-to-a-long-random-string
APP_URL=https://yourcabin.com
TRUSTED_EMAILS=

# Secret token to protect the iCal feed — append ?token=<value> when subscribing
# Leave empty to make the feed public (not recommended)
CALENDAR_TOKEN=change-this-to-a-random-string

# Optional prefix for calendar event titles (e.g. "🏡" or "Cabin:")
# Leave empty for no prefix
CALENDAR_PREFIX=🏡
